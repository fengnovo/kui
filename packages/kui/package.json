{
  "name": "@fengnovo/kui",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "engines": { "node": ">=18" },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./button": {
      "import": {
        "types": "./dist/button/index.d.ts",
        "default": "./dist/button/index.js"
      },
      "require": {
        "types": "./dist/button/index.d.cts",
        "default": "./dist/button/index.cjs"
      }
    },
    "./styles.css": "./dist/index.css"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && stylelint \"src/**/*.css\"",
    "check:publish": "publint && attw --pack"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@fengnovo/kui-tokens": "workspace:*",
    "class-variance-authority": "^0.7",
    "clsx": "^2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18",
    "@fengnovo/kui-tsconfig": "workspace:*",
    "@fengnovo/kui-eslint-config": "workspace:*",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^9",
    "publint": "^0.3",
    "react": "^18",
    "react-dom": "^18",
    "stylelint": "^16",
    "tsup": "^8",
    "typescript": "^5"
  }
}
