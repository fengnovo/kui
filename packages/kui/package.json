{
  "name": "@fengnovo/kui",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/fengnovo/kui",
    "directory": "packages/kui"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./button": {
      "import": {
        "types": "./dist/button/index.d.ts",
        "default": "./dist/button/index.js"
      },
      "require": {
        "types": "./dist/button/index.d.cts",
        "default": "./dist/button/index.cjs"
      }
    },
    "./select": {
      "import": {
        "types": "./dist/select/index.d.ts",
        "default": "./dist/select/index.js"
      },
      "require": {
        "types": "./dist/select/index.d.cts",
        "default": "./dist/select/index.cjs"
      }
    },
    "./switch": {
      "import": {
        "types": "./dist/switch/index.d.ts",
        "default": "./dist/switch/index.js"
      },
      "require": {
        "types": "./dist/switch/index.d.cts",
        "default": "./dist/switch/index.cjs"
      }
    },
    "./styles.css": "./dist/index.css"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && stylelint \"src/**/*.css\"",
    "test": "vitest run --coverage",
    "check:publish": "publint && attw --pack",
    "api:check": "api-extractor run --verbose",
    "api:update": "api-extractor run --local --verbose"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@fengnovo/kui-tokens": "workspace:*",
    "class-variance-authority": "^0.7",
    "clsx": "^2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18",
    "@microsoft/api-extractor": "^7",
    "@fengnovo/kui-tsconfig": "workspace:*",
    "@fengnovo/kui-eslint-config": "workspace:*",
    "@storybook/react": "^8",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^2",
    "eslint": "^9",
    "happy-dom": "^15",
    "publint": "^0.3",
    "react": "^18",
    "react-dom": "^18",
    "stylelint": "^16",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^2",
    "vitest-axe": "^0.1"
  }
}
